{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DeepSeek Code Agent",
  "version": "0.0.1",
  "identifier": "com.deepseek-code-agent",
  "build": {
    "beforeDevCommand": "npx vite",
    "beforeBuildCommand": "npx tsc && npx vite build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepSeek Code Agent",
        "width": 1280,
        "height": 840,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
